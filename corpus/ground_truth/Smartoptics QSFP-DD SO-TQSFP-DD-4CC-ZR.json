    {
      "table_id": "02_general_definitions",
      "title": "GENERAL DEFINITIONS",
      "page": 2,
      "headers": [
        "Parameter",
        "Description"
      ],
      "rows": [
        {
          "Parameter": "Technology",
          "Description": "Grey; Transceiver type for non-WDM applications. Electrical or optical. CWDM; Transceiver type for CWDM applications using G.694.2 channel grid. DWDM; Transceiver type for DWDM applications using G.694.1 channel grid. BiDi; Transceiver pair using two different wavelength channels operating on a single-fiber. DAC: Direct Attach Cable. Electrical cable with attached connectors. AOC: Active Optical Cable. Optical cable with attached connectors."
        },
        {
          "Parameter": "Transmission Media",
          "Description": "Type of fiber, e.g. Multimode (MM) or Singlemode (SM). Number of and connector type within brackets (e.g. 2x LC, 1x MPO)."
        },
        {
          "Parameter": "Typical reach",
          "Description": "Nominal distance performance based on typical fiber dispersion, fiber loss and power budget properties, i.e. w/o dispersion compensation and optical amplification. Actual distance is dependent on actual optical path loss and dispersion properties."
        },
        {
          "Parameter": "Bit rate range",
          "Description": "Supported bit rate range in Gigabit or Megabit per second (Gbps or Mbps)."
        },
        {
          "Parameter": "Protocols",
          "Description": "Protocols within supported bit rate range."
        },
        {
          "Parameter": "Nominal wavelength",
          "Description": "Typical wavelength(s) from transmitter."
        },
        {
          "Parameter": "Interface standards",
          "Description": "Referenced interface standards or MSA's, e.g. IEEE 802.3 standard for 10GbE services or 100G 4WDM-10 etc."
        },
        {
          "Parameter": "Power budget",
          "Description": "Min and max power budget between Transmitter and Receiver w/o optical path penalties."
        },
        {
          "Parameter": "Dispersion tolerance/penalty",
          "Description": "Maximum amount of tolerated dispersion and required reduction of power budget to maintain stipulated Bit Error Rate (BER) and at a given bit rate."
        },
        {
          "Parameter": "Temperature range",
          "Description": "Max operating case temperature range. Standard temperature range (C-temp): 0°C to +70°C (32°F to +158°F) Extended temperature range (E-temp): typically -20°C to +75°C (-4°F to +167°F) Industrial temperature range (I-temp): -40°C to +85°C (-40°F to +185°F)"
        },
        {
          "Parameter": "Power consumption",
          "Description": "Worst case power consumption. Will vary over temperature."
        },
        {
          "Parameter": "Transmitter Output power",
          "Description": "Average output power. Provided in min and max values."
        },
        {
          "Parameter": "Receiver minimum input power",
          "Description": "Minimum average input power at specified BER, normally 1E-'?. Note that some protocols require FEC to achieve sufficient BER."
        },
        {
          "Parameter": "Receiver max input power",
          "Description": "Maximum average input power giving a BER, normally 1E-1?."
        }
      ],
